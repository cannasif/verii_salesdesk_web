# (Opsiyonel) Backend API adresi. Yerel API icin ornek: http://localhost:5000
# Bos birakilirsa `npm run dev` istekleri Vite proxy uzerinden runtime-settings.json'daki API'ye yonlendirir.
# VITE_API_URL=http://localhost:5000

# (Opsiyonel) Yerel yardimci sunucunun adresi. Varsayilan: http://localhost:8787
# Sunucu (Gmail koprusu + sohbet) tek surecte calisir: npm run server
VITE_GMAIL_BRIDGE_URL=http://localhost:8787

# (Opsiyonel) Sohbet sunucusu farkli bir adreste ise. Bos birakilirsa yukaridaki adres kullanilir.
VITE_CHAT_SERVER_URL=http://localhost:8787
